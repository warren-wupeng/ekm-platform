# ── App ────────────────────────────────────────────────────────────────
APP_NAME="EKM API"
APP_VERSION=0.1.0
DEBUG=true

# ── Database (matches docker-compose service hostnames) ────────────────
DATABASE_URL=postgresql+asyncpg://ekm:ekm@postgres:5432/ekm

# ── Redis / Celery ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Search / Vector / Graph ────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
QDRANT_URL=http://qdrant:6333
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ekm_neo4j_pw

# ── Document parsing ───────────────────────────────────────────────────
TIKA_URL=http://tika:9998

# ── JWT ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── File storage ───────────────────────────────────────────────────────
# S3-compatible object storage (Fly Tigris, AWS S3, MinIO).
# Leave S3_BUCKET empty to fall back to local disk (dev).
S3_BUCKET=
S3_ENDPOINT_URL=https://fly.storage.tigris.dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Local fallback (dev only, when S3_BUCKET is empty)
UPLOAD_DIR=/tmp/ekm_uploads
MAX_UPLOAD_SIZE_MB=100

# ── LLM (LiteLLM) ──────────────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-6
LLM_BASE_URL=https://ai-gateway.happycapy.ai/api/v1
LLM_API_KEY=CHANGE_ME

# ── Internal service key (ekm-collab → ekm-backend) ─────────────────
# Used by Hocuspocus to call /api/v1/internal/* endpoints.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SERVICE_KEY=

# ── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
